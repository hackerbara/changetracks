<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<OfficeApp xmlns="http://schemas.microsoft.com/office/appforoffice/1.1"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xmlns:bt="http://schemas.microsoft.com/office/officeappbasictypes/1.0"
  xmlns:ov="http://schemas.microsoft.com/office/taskpaneappversionoverrides"
  xsi:type="TaskPaneApp">

  <!-- Unique add-in ID — do not reuse across add-ins -->
  <Id>a3f7c142-84b2-4e9d-b031-cd2e7f85a301</Id>
  <Version>1.0.0.0</Version>
  <ProviderName>ChangeDown</ProviderName>
  <DefaultLocale>en-US</DefaultLocale>
  <DisplayName DefaultValue="ChangeDown for Word"/>
  <Description DefaultValue="Bridge ChangeDown change-tracking annotations with Word&#39;s native Track Changes."/>
  <IconUrl DefaultValue="https://changedown.com/word/assets/icon-32.png"/>
  <HighResolutionIconUrl DefaultValue="https://changedown.com/word/assets/icon-64.png"/>
  <SupportUrl DefaultValue="https://github.com/alexdisler/changetracks"/>
  <!--
    AppDomains: origins the Word WebView is allowed to navigate to / load
    assets from.
      - https://changedown.com — hosted static task pane origin
      - https://127.0.0.1:39990 — the changedown-mcp fixed-port HTTPS endpoint the
        pane registers with. See docs/superpowers/plans/2026-04-21-word-sidebar-03b-pane-backend-client.md.
  -->
  <AppDomains>
    <AppDomain>https://changedown.com</AppDomain>
    <AppDomain>https://127.0.0.1:39990</AppDomain>
  </AppDomains>
  <Hosts>
    <Host Name="Document"/>
  </Hosts>
  <Requirements>
    <Sets DefaultMinVersion="1.1">
      <Set Name="WordApi" MinVersion="1.6"/>
      <Set Name="SharedRuntime" MinVersion="1.1"/>
    </Sets>
  </Requirements>
  <DefaultSettings>
    <SourceLocation DefaultValue="https://changedown.com/word/taskpane.html"/>
  </DefaultSettings>
  <Permissions>ReadWriteDocument</Permissions>

  <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides" xsi:type="VersionOverridesV1_0">
    <Hosts>
      <Host xsi:type="Document">
        <DesktopFormFactor>
          <GetStarted>
            <Title resid="GetStarted.Title"/>
            <Description resid="GetStarted.Description"/>
            <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
          </GetStarted>
          <FunctionFile resid="Commands.Url"/>
          <ExtensionPoint xsi:type="PrimaryCommandSurface">
            <OfficeTab id="TabHome">
              <Group id="ChangeDownGroup">
                <Label resid="CommandsGroup.Label"/>
                <Icon>
                  <bt:Image size="16" resid="Icon.16x16"/>
                  <bt:Image size="32" resid="Icon.32x32"/>
                  <bt:Image size="80" resid="Icon.80x80"/>
                </Icon>
                <Control xsi:type="Button" id="TaskpaneButton">
                  <Label resid="TaskpaneButton.Label"/>
                  <Supertip>
                    <Title resid="TaskpaneButton.Label"/>
                    <Description resid="TaskpaneButton.Tooltip"/>
                  </Supertip>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Action xsi:type="ShowTaskpane">
                    <TaskpaneId>ChangeDownTaskpane</TaskpaneId>
                    <SourceLocation resid="Taskpane.Url"/>
                  </Action>
                </Control>
              </Group>
            </OfficeTab>
          </ExtensionPoint>
        </DesktopFormFactor>
      </Host>
    </Hosts>
    <Resources>
      <bt:Images>
        <bt:Image id="Icon.16x16" DefaultValue="https://changedown.com/word/assets/icon-16.png"/>
        <bt:Image id="Icon.32x32" DefaultValue="https://changedown.com/word/assets/icon-32.png"/>
        <bt:Image id="Icon.80x80" DefaultValue="https://changedown.com/word/assets/icon-80.png"/>
      </bt:Images>
      <bt:Urls>
        <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://github.com/alexdisler/changetracks"/>
        <bt:Url id="Commands.Url" DefaultValue="https://changedown.com/word/commands.html"/>
        <bt:Url id="Taskpane.Url" DefaultValue="https://changedown.com/word/taskpane.html"/>
      </bt:Urls>
      <bt:ShortStrings>
        <bt:String id="GetStarted.Title" DefaultValue="ChangeDown for Word is ready"/>
        <bt:String id="CommandsGroup.Label" DefaultValue="ChangeDown"/>
        <bt:String id="TaskpaneButton.Label" DefaultValue="Open ChangeDown"/>
        <bt:String id="PG.ChangeDown.BrandingText" DefaultValue="ChangeDown"/>
        <bt:String id="PG.ChangeDown.SuggestionTitle" DefaultValue="Suggested Change"/>
        <bt:String id="PG.ChangeDown.SuggestionSubtitle" DefaultValue="Review this proposal"/>
      </bt:ShortStrings>
      <bt:LongStrings>
        <bt:String id="GetStarted.Description" DefaultValue="Click &#39;Open ChangeDown&#39; on the Home tab to start syncing ChangeDown annotations with Word Track Changes."/>
        <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the ChangeDown panel to import, export, and sync change annotations"/>
      </bt:LongStrings>
    </Resources>
    <!--
      Nested VersionOverrides V1.1 declares the SharedRuntime with
      lifetime="long" so the task pane web view persists across document
      navigation. Combined with Office.addin.setStartupBehavior(load) this
      causes the pane to auto-reopen on subsequent opens of the same doc.
      First-open still requires a manual activation — see taskpane.html hint.
      Requirement set: SharedRuntime 1.1 (also repeated in top-level
      Requirements for hosts that read the V1.0 block).
    -->
    <VersionOverrides xmlns="http://schemas.microsoft.com/office/taskpaneappversionoverrides/1.1" xsi:type="VersionOverridesV1_1">
      <Requirements>
        <Sets DefaultMinVersion="1.1">
          <Set Name="SharedRuntime" MinVersion="1.1"/>
        </Sets>
      </Requirements>
      <Hosts>
        <Host xsi:type="Document">
          <Runtimes>
            <Runtime resid="Taskpane.Url" lifetime="long"/>
          </Runtimes>
          <DesktopFormFactor>
            <GetStarted>
              <Title resid="GetStarted.Title"/>
              <Description resid="GetStarted.Description"/>
              <LearnMoreUrl resid="GetStarted.LearnMoreUrl"/>
            </GetStarted>
            <FunctionFile resid="Commands.Url"/>
            <ExtensionPoint xsi:type="PrimaryCommandSurface">
              <OfficeTab id="TabHome">
                <Group id="ChangeDownGroup">
                  <Label resid="CommandsGroup.Label"/>
                  <Icon>
                    <bt:Image size="16" resid="Icon.16x16"/>
                    <bt:Image size="32" resid="Icon.32x32"/>
                    <bt:Image size="80" resid="Icon.80x80"/>
                  </Icon>
                  <Control xsi:type="Button" id="TaskpaneButton">
                    <Label resid="TaskpaneButton.Label"/>
                    <Supertip>
                      <Title resid="TaskpaneButton.Label"/>
                      <Description resid="TaskpaneButton.Tooltip"/>
                    </Supertip>
                    <Icon>
                      <bt:Image size="16" resid="Icon.16x16"/>
                      <bt:Image size="32" resid="Icon.32x32"/>
                      <bt:Image size="80" resid="Icon.80x80"/>
                    </Icon>
                    <Action xsi:type="ShowTaskpane">
                      <TaskpaneId>ChangeDownTaskpane</TaskpaneId>
                      <SourceLocation resid="Taskpane.Url"/>
                    </Action>
                  </Control>
                </Group>
              </OfficeTab>
            </ExtensionPoint>
          </DesktopFormFactor>
        </Host>
      </Hosts>
      <Resources>
        <bt:Images>
          <bt:Image id="Icon.16x16" DefaultValue="https://changedown.com/word/assets/icon-16.png"/>
          <bt:Image id="Icon.32x32" DefaultValue="https://changedown.com/word/assets/icon-32.png"/>
          <bt:Image id="Icon.80x80" DefaultValue="https://changedown.com/word/assets/icon-80.png"/>
        </bt:Images>
        <bt:Urls>
          <bt:Url id="GetStarted.LearnMoreUrl" DefaultValue="https://github.com/alexdisler/changetracks"/>
          <bt:Url id="Commands.Url" DefaultValue="https://changedown.com/word/commands.html"/>
          <bt:Url id="Taskpane.Url" DefaultValue="https://changedown.com/word/taskpane.html"/>
        </bt:Urls>
        <bt:ShortStrings>
          <bt:String id="GetStarted.Title" DefaultValue="ChangeDown for Word is ready"/>
          <bt:String id="CommandsGroup.Label" DefaultValue="ChangeDown"/>
          <bt:String id="TaskpaneButton.Label" DefaultValue="Open ChangeDown"/>
          <bt:String id="PG.ChangeDown.BrandingText" DefaultValue="ChangeDown"/>
          <bt:String id="PG.ChangeDown.SuggestionTitle" DefaultValue="Suggested Change"/>
          <bt:String id="PG.ChangeDown.SuggestionSubtitle" DefaultValue="Review this proposal"/>
        </bt:ShortStrings>
        <bt:LongStrings>
          <bt:String id="GetStarted.Description" DefaultValue="Click &#39;Open ChangeDown&#39; on the Home tab to start syncing ChangeDown annotations with Word Track Changes."/>
          <bt:String id="TaskpaneButton.Tooltip" DefaultValue="Open the ChangeDown panel to import, export, and sync change annotations"/>
        </bt:LongStrings>
      </Resources>
    </VersionOverrides>
  </VersionOverrides>

</OfficeApp>
