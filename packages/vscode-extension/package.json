    "scripts": {
        "vscode:prepublish": "npm run esbuild -- --production",
        "compile": "tsc -p ./",
        "esbuild": "node esbuild.mjs",
        "watch": "tsc -watch -p ./",
        "package": "npx @vscode/vsce package --no-dependencies --allow-missing-repository",
        "pretest": "npm run compile && npm run lint",
        "lint": "eslint src --ext ts",
        "test": "npm run test:features",
        "test:fast": "npm run test:features:fast",
        "test:slow": "npm run test -w @changetracks/tests-vscode -- --tags '@slow and not @visual and not @wip'",
        "test:visual": "npm run test:visual -w @changetracks/tests-vscode",
        "test:visual:update": "npm run test:visual:update -w @changetracks/tests-vscode",
        "test:gaps": "npm run test:gaps -w @changetracks/tests-vscode",
        "test:features": "npm run compile && npm run test -w @changetracks/tests-vscode",
        "test:features:fast": "npm run compile && npm run test:fast -w @changetracks/tests-vscode",
        "test:features:slow": "npm run compile && npm run test:slow -w @changetracks/tests-vscode"
    },
