{
    "compilerOptions": {
        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out",
        "lib": [
            "ES2020"
        ],
        "sourceMap": true,
        "declaration": true,
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "@changedown/cli/init": ["../cli/dist/init/index.d.ts"],
            "@changedown/core/host": ["../core/dist/host/index.d.ts"]
        },
        // TODO: enable after fixing violations
        // "noUncheckedIndexedAccess": true,
        "noImplicitReturns": true,
        "noFallthroughCasesInSwitch": true,
        "forceConsistentCasingInFileNames": true
    },
    "exclude": [
        "node_modules",
        "out",
        ".vscode-test"
    ]
}
