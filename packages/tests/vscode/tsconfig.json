        "module": "commonjs",
        "target": "ES2020",
        "outDir": "out",
        "lib": ["ES2020"],
        "sourceMap": true,
        "rootDir": ".",
        "strict": true,
        "skipLibCheck": true,
        "paths": {
            "@changedown/cli/init": ["../../cli/dist/init/index.d.ts"],
            "changedown-vscode/internals": ["../../vscode-extension/out/internals"],
            "@changedown/lsp-server": ["../../lsp-server/dist/index"],
