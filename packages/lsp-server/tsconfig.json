{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "outDir": "dist",
    "rootDir": "src",
    "lib": ["ES2020"],
    "sourceMap": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "esModuleInterop": true,
    "paths": {
      "@changedown/cli/config": ["../cli/dist/config/index.d.ts"],
      "@changedown/core/host": ["../core/dist/host/index.d.ts"]
    },
    // TODO: enable after fixing violations
    // "noUncheckedIndexedAccess": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true
  },
  "references": [
    { "path": "../core" }
  ],
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "dist", "test", "src/browser-server.ts"]
}
