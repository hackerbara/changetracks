{
  "name": "@changedown/docx",
  "version": "0.4.5",
  "description": "DOCX import/export with tracked changes for ChangeDown",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "browser": [
        "dist/browser.d.ts"
      ],
      "inline-codec": [
        "dist/inline-codec/index.d.ts"
      ],
      "ooxml-codec": [
        "dist/ooxml-codec/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "default": "./dist/browser.js"
    },
    "./inline-codec": {
      "types": "./dist/inline-codec/index.d.ts",
      "default": "./dist/inline-codec/index.js"
    },
    "./ooxml-codec": {
      "types": "./dist/ooxml-codec/index.d.ts",
      "default": "./dist/ooxml-codec/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "test": "npm run typecheck:test && vitest run",
    "test:watch": "vitest",
    "typecheck:test": "tsc -p tsconfig.test.json --noEmit"
  },
  "dependencies": {
    "@changedown/core": "file:../core",
    "docx": "^9.5.0",
    "fast-xml-parser": "^5.5.8",
    "image-size": "^2.0.2",
    "jszip": "^3.10.0",
    "katex": "^0.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^4.1.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
