{
  "name": "@changedown/core",
  "version": "0.4.4",
  "description": "CriticMarkup parser and operations engine",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hackerbara/changedown.git"
  },
  "keywords": [
    "criticmarkup",
    "parser",
    "change-tracking",
    "markdown"
  ],
  "files": [
    "dist/",
    "!dist/test/",
    "!dist/src/",
    "dist-esm/",
    "README.md",
    "LICENSE"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "rm -rf dist dist-esm tsconfig.tsbuildinfo tsconfig.esm.tsbuildinfo",
    "prebuild": "npm run clean",
    "build": "npm run build:cjs && npm run build:esm",
    "build:cjs": "tsc -p ./tsconfig.json",
    "build:esm": "tsc -p ./tsconfig.esm.json && node -e \"require('fs').writeFileSync('dist-esm/package.json','{\\\"type\\\":\\\"module\\\"}')\""
  },
  "devDependencies": {
    "@types/diff": "^7.0.2",
    "@types/node": "20.2.5",
    "typescript": "^5.1.3"
  },
  "dependencies": {
    "diff": "^8.0.3",
    "xxhash-wasm": "^1.1.0"
  },
  "module": "dist-esm/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist-esm/index.js",
      "require": "./dist/index.js"
    },
    "./internals": {
      "types": "./dist/internals.d.ts",
      "import": "./dist-esm/internals.js",
      "require": "./dist/internals.js"
    },
    "./edit-boundary": {
      "types": "./dist/edit-boundary/index.d.ts",
      "import": "./dist-esm/edit-boundary/index.js",
      "require": "./dist/edit-boundary/index.js"
    },
    "./host": {
      "types": "./dist/host/index.d.ts",
      "import": "./dist-esm/host/index.js",
      "require": "./dist/host/index.js"
    },
    "./host/services": {
      "types": "./dist/host/services/index.d.ts",
      "import": "./dist-esm/host/services/index.js",
      "require": "./dist/host/services/index.js"
    },
    "./backend": {
      "types": "./dist/backend/index.d.ts",
      "import": "./dist-esm/backend/index.js",
      "require": "./dist/backend/index.js"
    }
  }
}
