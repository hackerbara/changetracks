{
  "name": "@changedown/mcp",
  "version": "0.4.4",
  "description": "MCP server for ChangeDown — durable change tracking for AI agents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/hackerbara/changedown.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "criticmarkup",
    "ai-agents",
    "change-tracking"
  ],
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./internals": "./dist/internals.js",
    "./transport/fixed-port-leader": "./dist/transport/fixed-port-leader.js",
    "./transport/streamable-http": "./dist/transport/streamable-http.js",
    "./transport/client-proxy": "./dist/transport/client-proxy.js",
    "./transport/pane-endpoint": "./dist/transport/pane-endpoint.js",
    "./remote-backend": "./dist/remote-backend.js",
    "./pane-registration": "./dist/pane-registration.js",
    "./package.json": "./package.json"
  },
  "bin": {
    "changedown-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "build:tsc": "tsc",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@changedown/core": "file:../../packages/core",
    "@changedown/cli": "file:../../packages/cli",
    "commander": "^13.1.0",
    "diff": "^8.0.3",
    "picomatch": "^4.0.0",
    "smol-toml": "^1.3.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/picomatch": "^3.0.0",
    "@types/ws": "^8.5.0",
    "typescript": "^5.3.0"
  }
}
